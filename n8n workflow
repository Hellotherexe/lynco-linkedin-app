        "respondWith": "text",
        "responseBody": "=<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Lyn & Co Realty | Strategic AI Generator</title>\n    <style>\n        :root {\n            --primary: #0a192f;\n            --gold: #c5a059;\n            --gold-light: #e0c58a;\n            --bg: #f4f7f9;\n            --white: #ffffff;\n            --text: #1a202c;\n            --success: #28a745;\n        }\n        body { font-family: 'Inter', -apple-system, sans-serif; background: var(--bg); margin: 0; padding: 0; color: var(--text); }\n        header { background: var(--primary); color: var(--white); padding: 3rem 1rem; text-align: center; border-bottom: 5px solid var(--gold); }\n        .container { max-width: 900px; margin: -50px auto 50px; padding: 0 20px; }\n        \n        /* Main Upload Card */\n        .card { background: var(--white); border-radius: 16px; padding: 40px; box-shadow: 0 20px 40px rgba(0,0,0,0.08); border: 1px solid rgba(0,0,0,0.05); }\n        h1 { margin: 0; letter-spacing: 4px; text-transform: uppercase; font-size: 1.8rem; font-weight: 300; }\n        p.subtitle { color: var(--gold); font-size: 0.9rem; letter-spacing: 2px; text-transform: uppercase; margin-top: 10px; }\n        \n        .upload-area { border: 2px dashed #d1d5db; padding: 40px; text-align: center; border-radius: 12px; margin: 20px 0; transition: all 0.3s ease; background: #fafafa; cursor: pointer; }\n        .upload-area:hover { border-color: var(--gold); background: #fffdf9; }\n        \n        button { background: var(--primary); color: white; border: 1px solid var(--gold); padding: 16px 45px; border-radius: 4px; font-weight: 600; cursor: pointer; transition: 0.3s; font-size: 0.9rem; letter-spacing: 1px; text-transform: uppercase; }\n        button:hover { background: var(--gold); color: var(--primary); transform: translateY(-2px); }\n        button:disabled { background: #cbd5e0; border-color: #cbd5e0; cursor: not-allowed; transform: none; color: white; }\n        \n        .approve-btn { background: var(--success); border: none; width: 100%; margin-top: 20px; padding: 18px; border-radius: 8px; font-size: 1rem; }\n        .approve-btn:hover { background: #218838; color: white; }\n\n        /* Results Feed */\n        #results { margin-top: 50px; display: grid; gap: 40px; }\n        .post-card { background: white; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); overflow: hidden; transition: 0.3s; border: 1px solid #eee; }\n        .post-card.approved { opacity: 0.5; pointer-events: none; transform: scale(0.98); }\n        \n        .post-header { background: var(--primary); color: var(--gold); padding: 15px 25px; font-size: 0.8rem; font-weight: bold; text-transform: uppercase; letter-spacing: 1.5px; display: flex; justify-content: space-between; }\n        .post-image { width: 100%; max-height: 400px; object-fit: contain; background: #000; display: block; border-bottom: 1px solid #eee; }\n        \n        /* Editable Content Area */\n        .post-body { padding: 30px; line-height: 1.8; font-size: 1.05rem; outline: none; }\n        .post-body:focus { background: #fffdf5; border-radius: 8px; }\n        .post-body p { margin-bottom: 15px; }\n        \n        .loader { display: none; text-align: center; padding: 30px; color: var(--primary); font-weight: 600; }\n        .file-chip { background: #edf2f7; padding: 8px 16px; border-radius: 6px; font-size: 0.85rem; color: var(--primary); border: 1px solid #e2e8f0; }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Lyn & Co Realty</h1>\n        <p class=\"subtitle\">Strategic Property Intelligence</p>\n    </header>\n    <div class=\"container\">\n        <div class=\"card\">\n            <div class=\"upload-area\" onclick=\"document.getElementById('fileInput').click()\">\n                <p style=\"margin:0 0 10px; font-size: 1.1rem;\">Click to Upload Articles</p>\n                <p style=\"margin:0; font-size: 0.85rem; color: #718096;\">Images will be processed into individual LinkedIn drafts.</p>\n                <input type=\"file\" id=\"fileInput\" multiple accept=\"image/*\" onchange=\"previewFiles()\" style=\"display:none\">\n            </div>\n            <div id=\"filePreview\" class=\"file-preview\" style=\"display:flex; gap:10px; flex-wrap:wrap; margin-bottom:15px;\"></div>\n            <div style=\"text-align:center;\">\n                <button id=\"btn\" onclick=\"process()\">Generate Luxury Insights</button>\n            </div>\n            <div id=\"loader\" class=\"loader\">⏳ ANALYZING MARKET DATA...</div>\n        </div>\n        <div id=\"results\"></div>\n    </div>\n\n    <script>\n    let uploadedFiles = [];\n    let generatedPosts = [];\n\n    // Helper function to convert a File object to a Base64 string\n    const toBase64 = file => new Promise((resolve, reject) => {\n        const reader = new FileReader();\n        reader.readAsDataURL(file);\n        reader.onload = () => resolve(reader.result);\n        reader.onerror = error => reject(error);\n    });\n\n    function previewFiles() {\n        const files = document.getElementById('fileInput').files;\n        uploadedFiles = Array.from(files);\n        const preview = document.getElementById('filePreview');\n        preview.innerHTML = uploadedFiles.map(f => `<span class=\"file-chip\">🖼️ ${f.name}</span>`).join('');\n    }\n\n    async function process() {\n        if (uploadedFiles.length === 0) return alert('Please select article screenshots first.');\n        \n        const btn = document.getElementById('btn');\n        const loader = document.getElementById('loader');\n        btn.disabled = true;\n        loader.style.display = 'block';\n        document.getElementById('results').innerHTML = '';\n        \n        const formData = new FormData();\n        for (const file of uploadedFiles) {\n            formData.append('file', file);\n        }\n        \n        try {\n            const response = await fetch(window.location.origin + '/webhook/batch-processor', {\n                method: 'POST',\n                body: formData\n            });\n    \n            if (!response.ok) throw new Error(`Server returned ${response.status}`);\n    \n            const responseText = await response.text();\n            const data = JSON.parse(responseText);\n            \n            // Map the AI text to our generatedPosts array\n            generatedPosts = data.posts; \n    \n            if (!generatedPosts || generatedPosts.length === 0) {\n                throw new Error(\"No posts were generated.\");\n            }\n    \n            let html = '';\n            generatedPosts.forEach((item, index) => {\n                const file = uploadedFiles[index];\n                const localImageUrl = file ? URL.createObjectURL(file) : '';\n                const postContent = typeof item.post === 'string' ? item.post : JSON.stringify(item.post);\n    \n                html += `\n                    <div class=\"post-card\" id=\"card-${index}\">\n                        <div class=\"post-header\">\n                            <span>STRATEGIC INSIGHT #${index + 1}</span>\n                            <span>${file ? file.name : 'ARTICLE'}</span>\n                        </div>\n                        <img class=\"post-image\" src=\"${localImageUrl}\" alt=\"Article Image\">\n                        <div class=\"post-body\" id=\"content-${index}\" contenteditable=\"true\">\n                            ${postContent.split('\\n').map(line => line.trim() ? `<p>${line}</p>` : '').join('')}\n                        </div>\n                        <div style=\"padding: 0 30px 30px;\">\n                            <button class=\"approve-btn\" id=\"btn-${index}\" onclick=\"approvePost(${index})\">🚀 Approve & Post to LinkedIn</button>\n                        </div>\n                    </div>\n                `;\n            });\n    \n            document.getElementById('results').innerHTML = html;\n    \n        } catch (e) {\n            console.error(\"Process Error:\", e);\n            alert('Generation Error: ' + e.message);\n        } finally {\n            btn.disabled = false;\n            loader.style.display = 'none';\n        }\n    }\n\n    async function approvePost(index) {\n        const card = document.getElementById(`card-${index}`);\n        const btn = document.getElementById(`btn-${index}`);\n        const editedText = document.getElementById(`content-${index}`).innerText;\n        const file = uploadedFiles[index]; // Get the original file\n\n        if (!confirm(\"Are you sure you want to approve and post this to LinkedIn?\")) return;\n\n        try {\n            btn.disabled = true;\n            btn.innerText = \"⌛ SENDING...\";\n\n            // CRITICAL FIX: Convert the local file to Base64 right here\n            const base64Image = await toBase64(file);\n\n            const response = await fetch(window.location.origin + '/webhook/approve-linkedin', {\n                method: 'POST',\n                headers: { 'Content-Type': 'application/json' },\n                body: JSON.stringify({\n                    postContent: editedText,\n                    image: base64Image,      // Now this is the actual image string!\n                    mime: file.type          // Now this is the actual mime type!\n                })\n            });\n\n            if (response.ok) {\n                card.classList.add('approved');\n                btn.innerText = \"✅ PUBLISHED\";\n                alert('Success! Post sent to LinkedIn.');\n            } else {\n                throw new Error('Server rejected approval');\n            }\n        } catch (e) {\n            btn.disabled = false;\n            btn.innerText = \"🚀 Approve & Post to LinkedIn\";\n            alert('Approval Failed: ' + e.message);\n        }\n    }\n</script>\n</body>\n</html>",
