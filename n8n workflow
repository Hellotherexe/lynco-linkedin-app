      "parameters": {
        "jsCode": "const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));\n\nconst binaryKeys = Object.keys(items[0].binary);\nconst rawText = [];\nconst debugInfo = [];\n\nfor (let i = 0; i < binaryKeys.length; i++) {\n  const key = binaryKeys[i];\n  const binaryData = await this.helpers.getBinaryDataBuffer(0, key);\n  const base64 = binaryData.toString('base64');\n  const mimeType = items[0].binary[key].mimeType;\n\n  try {\n    const ocrResponse = await this.helpers.httpRequest({\n      method: 'POST',\n      url: 'https://api.ocr.space/parse/image',\n      headers: { 'apikey': 'INSERT API KEY HERE' },\n      timeout: 30000, // 30-second timeout per individual image\n      body: {\n        language: 'eng',\n        isOverlayRequired: 'false',\n        base64Image: `data:${mimeType};base64,${base64}`\n      },\n      form: true \n    });\n\n    const text = ocrResponse?.ParsedResults?.[0]?.ParsedText || '';\n    if (text.trim()) {\n      rawText.push(text.trim());\n    }\n    \n    debugInfo.push({ file: key, status: 'success', length: text.length });\n\n  } catch (err) {\n    debugInfo.push({ file: key, status: 'error', message: err.message });\n    // If one fails, we still want to try the others\n  }\n\n  // Mandatory gap to prevent OCR Space API from hanging up on multiple large uploads\n  await sleep(4000); \n}\n\nreturn [{\n  json: {\n    rawText,\n    debugInfo,\n    totalFiles: binaryKeys.length,\n    totalTexts: rawText.length\n  }\n}];"
