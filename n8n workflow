    {
      "parameters": {
        "jsCode": "// 1. Safely grab the text from the previous Gemini/AI node\nconst rawText = $input.first().json.text || \"\";\n\n// If Gemini failed or sent nothing, return an empty array to prevent the frontend from crashing\nif (!rawText || rawText.trim() === \"\") {\n    return [{ json: { posts: [] } }];\n}\n\nlet posts = [];\n\ntry {\n    // 2. Attempt a clean parse (stripping markdown backticks)\n    const cleaned = rawText.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n    posts = JSON.parse(cleaned);\n} catch (e) {\n    // 3. Fallback: Manually find the JSON array [] using string indexing \n    // This avoids the 'Invalid regular expression' error entirely\n    const startIdx = rawText.indexOf('[');\n    const endIdx = rawText.lastIndexOf(']');\n    \n    if (startIdx !== -1 && endIdx !== -1 && endIdx > startIdx) {\n        const jsonString = rawText.substring(startIdx, endIdx + 1);\n        try {\n            posts = JSON.parse(jsonString);\n        } catch (innerError) {\n            console.error(\"Manual JSON extract failed:\", innerError);\n            posts = [];\n        }\n    }\n}\n\n// 4. Map the binary images (screenshots) to the parsed posts\n// This ensures Post #1 uses Image #1, etc.\nconst finalPosts = posts.map((p, index) => {\n    // Access binary data from the input item\n    const binaryKeys = Object.keys($input.first().binary || {});\n    const key = binaryKeys[index];\n    \n    return {\n        ...p,\n        // Passing the Base64 data and mimeType to the frontend\n        imageBase64: key ? $input.first().binary[key].data : null,\n        mimeType: key ? $input.first().binary[key].mimeType : null\n    };\n});\n\nreturn [{ json: { posts: finalPosts } }];"
